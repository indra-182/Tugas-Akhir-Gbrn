db.driver=com.mysql.cj.jdbc.Driver

# Salin file ini menjadi config.properties (folder yang sama), lalu isi
# kredensial sungguhan. config.properties tidak ikut repo (.gitignore).
# Setelah diisi, Clean and Build agar ter-bundle ke JAR.

# --- LOKAL (MySQL di laptop sendiri) ---
